<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Wall-E" Height="850" Width="440"
        MinHeight="500" MinWidth="380"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="#0C0C10">

    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#16161B"/>
        <SolidColorBrush x:Key="BorderBrush2" Color="#2A2A30"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#D8A94A"/>
        <SolidColorBrush x:Key="TextBrush" Color="#E8E8E8"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#8C8C94"/>

        <Style TargetType="Button" x:Key="NavButton">
            <Setter Property="Background" Value="#1E1E24"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush2}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="PrimaryButton" BasedOn="{StaticResource NavButton}">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#1A1400"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <Style TargetType="RadioButton" x:Key="SpeedOption">
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="OptBorder" Background="#1E1E24" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="OptBorder" Property="Background" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="#1A1400"/>
                                <Setter TargetName="OptBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header + Preview: this row is star-sized, so it grows to fill
             whatever extra space the window has - maximizing the app now
             makes the picture itself fill the screen, instead of staying
             pinned at a small fixed size. -->
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="W A L L - E" FontFamily="Consolas" FontSize="26" FontWeight="Bold"
                               Foreground="#39FF7A">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#39FF7A" BlurRadius="18" ShadowDepth="0" Opacity="0.9"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Movie snapshots as your desktop background" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                </StackPanel>
                <Button x:Name="BtnHowTo" Grid.Column="1" Content="?  How to Use" Style="{StaticResource NavButton}"
                        VerticalAlignment="Top" Padding="12,6" FontSize="12" ToolTip="Getting started, shortcuts, and why it beats the built-in slideshow"/>
            </Grid>

            <Grid Grid.Row="1">
                <Border MinHeight="180" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush2}" BorderThickness="1" CornerRadius="8">
                    <Image x:Name="ImgPreview" Stretch="Uniform" Margin="6"/>
                </Border>

                <!-- Overlay toolbar: preview fit mode + full-screen button -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,10,10,0">
                    <ComboBox x:Name="CmbPreviewStretch" Width="92" Margin="0,0,6,0" ToolTip="Preview fit mode">
                        <ComboBoxItem Content="Fit" Tag="Uniform" IsSelected="True"/>
                        <ComboBoxItem Content="Fill" Tag="UniformToFill"/>
                        <ComboBoxItem Content="Stretch" Tag="Fill"/>
                        <ComboBoxItem Content="Center" Tag="None"/>
                    </ComboBox>
                    <Button x:Name="BtnFullScreen" Content="⛶" Style="{StaticResource NavButton}" Width="36" Padding="0" ToolTip="Full screen preview"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Everything below the preview: sized to its content and
             scrollable, so it never eats into the preview's space and
             still works if the window gets short. -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,10,0,0">
        <StackPanel>

            <!-- Folder / image info -->
            <StackPanel Margin="0,0,0,0">
                <TextBlock x:Name="TxtFolderName" Text="No folder loaded" FontSize="15" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="TxtImageInfo" Text="—" FontSize="12" Foreground="{StaticResource MutedTextBrush}" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Directional controls (mirrors arrow keys) -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Button x:Name="BtnUp" Grid.Row="0" Grid.Column="1" Content="▲ Next Folder" Style="{StaticResource NavButton}" Margin="3"/>

                <Button x:Name="BtnLeft" Grid.Row="1" Grid.Column="0" Content="◀ Prev Wallpaper" Style="{StaticResource NavButton}" Margin="3"/>
                <Button x:Name="BtnDown" Grid.Row="1" Grid.Column="1" Content="▼ Prev Folder" Style="{StaticResource NavButton}" Margin="3"/>
                <Button x:Name="BtnRight" Grid.Row="1" Grid.Column="2" Content="Next Wallpaper ▶" Style="{StaticResource NavButton}" Margin="3"/>
            </Grid>

            <!-- Root folder -->
            <StackPanel Margin="0,14,0,0">
                <TextBlock Text="LIBRARY FOLDER" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                <Grid Margin="0,4,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtRootPath" Grid.Column="0" IsReadOnly="True" Background="{StaticResource PanelBrush}" Foreground="{StaticResource TextBrush}" BorderBrush="{StaticResource BorderBrush2}" Padding="6" VerticalContentAlignment="Center"/>
                    <Button x:Name="BtnBrowse" Grid.Column="1" Content="Browse…" Style="{StaticResource NavButton}" Margin="6,0,0,0" Padding="10,6"/>
                </Grid>
            </StackPanel>

            <!-- Style -->
            <Grid Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="WALLPAPER STYLE" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                    <ComboBox x:Name="CmbStyle" Margin="0,4,6,0">
                        <ComboBoxItem Content="Fill"/>
                        <ComboBoxItem Content="Fit"/>
                        <ComboBoxItem Content="Stretch"/>
                        <ComboBoxItem Content="Center"/>
                        <ComboBoxItem Content="Span"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Bottom">
                    <CheckBox x:Name="ChkHotkeys" Content="Hotkeys enabled (global)" Foreground="{StaticResource TextBrush}" Margin="6,0,0,8" IsChecked="True"
                              ToolTip="Global arrows (navigate) + S (slideshow) + P (quick play) control Wall-E system-wide. Press Ctrl+Alt+W anywhere to toggle the whole group on/off without reopening the app."/>
                    <TextBlock Text="Toggle anywhere: Ctrl+Alt+W" FontSize="10" Foreground="{StaticResource MutedTextBrush}" Margin="6,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Slideshow settings (mirrors Windows' own slideshow options) -->
            <StackPanel Margin="0,14,0,0">
                <TextBlock Text="SLIDESHOW" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Change picture every" Foreground="{StaticResource TextBrush}" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CmbInterval" Grid.Column="1" Width="150">
                        <ComboBoxItem Content="5 seconds" Tag="5"/>
                        <ComboBoxItem Content="10 seconds" Tag="10"/>
                        <ComboBoxItem Content="30 seconds" Tag="30" IsSelected="True"/>
                        <ComboBoxItem Content="1 minute" Tag="60"/>
                        <ComboBoxItem Content="10 minutes" Tag="600"/>
                        <ComboBoxItem Content="30 minutes" Tag="1800"/>
                        <ComboBoxItem Content="1 hour" Tag="3600"/>
                        <ComboBoxItem Content="6 hours" Tag="21600"/>
                        <ComboBoxItem Content="1 day" Tag="86400"/>
                    </ComboBox>
                </Grid>
                <CheckBox x:Name="ChkShuffle" Content="Shuffle the picture order" Foreground="{StaticResource TextBrush}" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Quick play (stop-motion style flip through images at a fixed pace) -->
            <StackPanel Margin="0,14,0,0">
                <TextBlock Text="QUICK PLAY" FontSize="11" Foreground="{StaticResource MutedTextBrush}"/>
                <Grid Margin="0,6,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <RadioButton x:Name="RbSpeedLow" Grid.Column="0" Content="Low-paced" GroupName="QuickPlaySpeed" Style="{StaticResource SpeedOption}" Margin="0,0,3,0"/>
                    <RadioButton x:Name="RbSpeedMedium" Grid.Column="1" Content="Medium-paced" GroupName="QuickPlaySpeed" Style="{StaticResource SpeedOption}" Margin="3,0" IsChecked="True"/>
                    <RadioButton x:Name="RbSpeedHigh" Grid.Column="2" Content="High-paced" GroupName="QuickPlaySpeed" Style="{StaticResource SpeedOption}" Margin="3,0,0,0"/>
                </Grid>
                <Button x:Name="BtnQuickPlay" Content="▶ Play (P)" Style="{StaticResource NavButton}" Margin="0,8,0,0" Padding="10,8"/>
            </StackPanel>

            <!-- Slideshow / Refresh -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnPlay" Grid.Column="0" Content="▶ Start Slideshow (S)" Style="{StaticResource NavButton}" Margin="0,0,6,0" Padding="10,8"/>
                <Button x:Name="BtnRefresh" Grid.Column="1" Content="Rescan Library" Style="{StaticResource PrimaryButton}" Padding="10,8"/>
            </Grid>

            <!-- Status bar -->
            <Border BorderBrush="{StaticResource BorderBrush2}" BorderThickness="0,1,0,0" Margin="0,10,0,0" Padding="0,8,0,0">
                <TextBlock x:Name="TxtStatus" Text="Ready." FontSize="11" Foreground="{StaticResource MutedTextBrush}" TextWrapping="Wrap"/>
            </Border>

        </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
